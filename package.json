{
  "name": "codex-gstack-macos",
  "version": "0.1.0",
  "private": true,
  "description": "Codex-only, macOS-only local workflow and browser tooling.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "security": "node scripts/check-security.mjs",
    "doctor": "bash scripts/doctor.sh",
    "browser:start": "tsx src/browser/cli.ts daemon start",
    "browser:stop": "tsx src/browser/cli.ts daemon stop",
    "browser:status": "tsx src/browser/cli.ts daemon status",
    "browser:token": "tsx src/browser/cli.ts daemon token",
    "browser:screenshot": "tsx src/browser/cli.ts page screenshot",
    "browser:snapshot": "tsx src/browser/cli.ts page snapshot",
    "browser:cookies:list": "tsx src/browser/cli.ts cookies list-domains",
    "browser:cookies:import": "tsx src/browser/cli.ts cookies import"
  },
  "dependencies": {
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.29.1",
    "vitest": "^4.1.4"
  }
}
